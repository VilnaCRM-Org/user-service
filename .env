###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

XDEBUG_MODE=off

###> oauth-social-signin ###
# OAuth Social Sign-In Client Configuration
# IMPORTANT: Callback URIs MUST use HTTPS in production and staging environments.
# In dev/test, HTTP is acceptable (e.g., http://localhost).
# Each provider requires a client ID and secret obtained from the provider's developer console.

OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=${API_BASE_URL}/api/auth/social/github/callback

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=${API_BASE_URL}/api/auth/social/google/callback

OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_FACEBOOK_REDIRECT_URI=${API_BASE_URL}/api/auth/social/facebook/callback
OAUTH_FACEBOOK_GRAPH_API_VERSION=v19.0

OAUTH_TWITTER_CLIENT_ID=
OAUTH_TWITTER_CLIENT_SECRET=
OAUTH_TWITTER_REDIRECT_URI=${API_BASE_URL}/api/auth/social/twitter/callback

# Outbound HTTP resilience for provider API calls
OAUTH_PROVIDER_HTTP_CONNECT_TIMEOUT_MS=1500
OAUTH_PROVIDER_HTTP_MAX_RETRIES=1
OAUTH_PROVIDER_HTTP_TIMEOUT_MS=5000

# OAuth state TTL in seconds (default: 600 = 10 minutes)
OAUTH_STATE_TTL_SECONDS=600
###< oauth-social-signin ###
