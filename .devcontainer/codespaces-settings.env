# Repository-tracked defaults for GitHub Codespaces bootstrap.
# Secrets must stay in Codespaces secrets, not in git.

CLAUDE_NPM_PACKAGE="${CLAUDE_NPM_PACKAGE:-@anthropic-ai/claude-code}"
CLAUDE_MODEL="${CLAUDE_MODEL:-MiniMax-M2.7}"
CLAUDE_BASE_URL="${CLAUDE_BASE_URL:-https://api.minimax.io/anthropic}"
# Unsafe-by-default autonomous configuration for Codespaces.
CLAUDE_PERMISSION_MODE="${CLAUDE_PERMISSION_MODE:-bypassPermissions}"
CLAUDE_ALLOW_UNSAFE_MODE="${CLAUDE_ALLOW_UNSAFE_MODE:-1}"
CLAUDE_TOOL_SMOKE_MODE="${CLAUDE_TOOL_SMOKE_MODE:-enforce}"

GH_HOST="${GH_HOST:-github.com}"
GH_GIT_PROTOCOL="${GH_GIT_PROTOCOL:-ssh}"
GH_PROMPT="${GH_PROMPT:-disabled}"
GH_TOKEN_VAR="${GH_TOKEN_VAR:-GH_AUTOMATION_TOKEN}"

CODESPACE_GITHUB_ORG="${CODESPACE_GITHUB_ORG:-VilnaCRM-Org}"
CODESPACE_GIT_IDENTITY_NAME="${CODESPACE_GIT_IDENTITY_NAME:-vilnacrm ai bot}"
CODESPACE_GIT_IDENTITY_EMAIL="${CODESPACE_GIT_IDENTITY_EMAIL:-info@vilnacrm.com}"
