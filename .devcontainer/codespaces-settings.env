# Repository-tracked defaults for workspace bootstrap.
# Legacy CODESPACE_* variable names are kept for compatibility.
# Secrets must stay in workspace secrets, not in git.

CODEX_NPM_PACKAGE="${CODEX_NPM_PACKAGE:-@openai/codex}"
CODEX_SMOKE_MODEL="${CODEX_SMOKE_MODEL:-}"
CODEX_TOOL_SMOKE_MODE="${CODEX_TOOL_SMOKE_MODE:-enforce}"

GH_HOST="${GH_HOST:-github.com}"
GH_GIT_PROTOCOL="${GH_GIT_PROTOCOL:-ssh}"
GH_PROMPT="${GH_PROMPT:-disabled}"
GH_TOKEN_VAR="${GH_TOKEN_VAR:-GH_AUTOMATION_TOKEN}"

CODESPACE_GITHUB_ORG="${CODESPACE_GITHUB_ORG:-VilnaCRM-Org}"
CODESPACE_GIT_IDENTITY_NAME="${CODESPACE_GIT_IDENTITY_NAME:-vilnacrm ai bot}"
CODESPACE_GIT_IDENTITY_EMAIL="${CODESPACE_GIT_IDENTITY_EMAIL:-info@vilnacrm.com}"
