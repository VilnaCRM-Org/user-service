# Repository-tracked defaults for workspace bootstrap.
# Keep secrets in your workspace secret store or environment, not in git.

CODEX_NPM_PACKAGE="${CODEX_NPM_PACKAGE:-@openai/codex}"
CODEX_SMOKE_MODEL="${CODEX_SMOKE_MODEL:-}"
CODEX_TOOL_SMOKE_MODE="${CODEX_TOOL_SMOKE_MODE:-skip}"

GH_HOST="${GH_HOST:-github.com}"
GH_GIT_PROTOCOL="${GH_GIT_PROTOCOL:-ssh}"
GH_PROMPT="${GH_PROMPT:-disabled}"
GH_TOKEN_VAR="${GH_TOKEN_VAR:-GH_AUTOMATION_TOKEN}"

WORKSPACE_GITHUB_ORG="${WORKSPACE_GITHUB_ORG:-VilnaCRM-Org}"

WORKSPACE_GIT_IDENTITY_NAME="${WORKSPACE_GIT_IDENTITY_NAME:-vilnacrm ai bot}"
WORKSPACE_GIT_IDENTITY_EMAIL="${WORKSPACE_GIT_IDENTITY_EMAIL:-info@vilnacrm.com}"
WORKSPACE_GIT_COMMITTER_NAME="${WORKSPACE_GIT_COMMITTER_NAME:-}"
WORKSPACE_GIT_COMMITTER_EMAIL="${WORKSPACE_GIT_COMMITTER_EMAIL:-}"
