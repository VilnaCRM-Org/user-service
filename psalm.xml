<?xml version="1.0"?>
<psalm
        errorLevel="8"
        resolveFromConfigFile="true"
        findUnusedVariablesAndParams="true"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="https://getpsalm.org/schema/config"
        xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
>
    <projectFiles>
        <directory name="src"/>
        <directory name="tests"/>
        <ignoreFiles>
            <directory name="vendor"/>
            <directory name="tests/CLI"/>
        </ignoreFiles>
    </projectFiles>
    <plugins>
        <pluginClass class="Psalm\PhpUnitPlugin\Plugin"/>
    </plugins>
    <!-- Forbid plain json_encode/json_decode in favour of Symfony Serializer.
         Violations surface as ForbiddenCode and are suppressed in tests/. -->
    <forbiddenFunctions>
        <function name="json_encode"/>
        <function name="json_decode"/>
    </forbiddenFunctions>
    <!-- Behat contexts use annotations (@Given/@When/@Then) to call methods,
         and properties are serialized to JSON for API requests.
         Psalm 6+ has stricter unused code detection that cannot trace these
         framework-level invocations. -->
    <issueHandlers>
        <UnusedClass>
            <errorLevel type="suppress">
                <directory name="tests/Behat"/>
            </errorLevel>
        </UnusedClass>
        <PossiblyUnusedMethod>
            <errorLevel type="suppress">
                <directory name="tests/Behat"/>
            </errorLevel>
        </PossiblyUnusedMethod>
        <UnusedParam>
            <errorLevel type="suppress">
                <directory name="tests/Behat"/>
            </errorLevel>
        </UnusedParam>
        <ForbiddenCode>
            <errorLevel type="suppress">
                <directory name="tests"/>
            </errorLevel>
        </ForbiddenCode>
    </issueHandlers>
</psalm>
