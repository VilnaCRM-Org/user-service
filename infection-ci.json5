{
  "$schema": "vendor/infection/infection/resources/schema.json",
  "source": {
    "directories": [
      "src"
    ],
    "excludes": [
      "DataFixtures",
      "Shared/Application/Resolver/RateLimit/ApiRateLimitAuthTargetResolver.php",
      "Shared/Application/Resolver/RateLimit/ApiRateLimitClientIdentityResolver.php",
      "Shared/Application/Resolver/RateLimit/ApiRateLimitRequestResolver.php",
      "Shared/Infrastructure/Security/DualAuthenticator.php",
      "User/Application/Processor/ResendEmailProcessor.php"
    ],
  },
  "logs": {
    "text": "infection.log",
    "summary": "summary.log",
  },
  "mutators": {
    "@default": true,
    "IncrementInteger": {
      "ignore": [
        "App\\User\\Infrastructure\\TwoFactor\\TOTPCreator::generateSecret"
      ]
    },
    "DecrementInteger": {
      "ignore": [
        "App\\User\\Infrastructure\\TwoFactor\\TOTPCreator::generateSecret"
      ]
    },
    "CastInt": {
      "ignore": [
        "App\\User\\Application\\CommandHandler\\RefreshTokenCommandHandler::isLaterRotatedToken"
      ]
    },
    "GreaterThan": {
      "ignore": [
        "App\\User\\Application\\CommandHandler\\RefreshTokenCommandHandler::isLaterRotatedToken"
      ]
    },
    "ReturnRemoval": {
      "ignore": [
        "App\\User\\Application\\CommandHandler\\RefreshTokenCommandHandler::isLaterRotatedToken"
      ]
    }
  },
}
