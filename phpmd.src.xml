<?xml version="1.0"?>
<ruleset name="Source Code Rules"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0
                     http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>
        Production source code rules. Covers codesize, design, and cleancode categories
        with project-specific configuration for third-party library boundaries.
    </description>

    <rule ref="rulesets/codesize.xml"/>

    <rule ref="rulesets/design.xml"/>

    <rule ref="rulesets/cleancode.xml/BooleanArgumentFlag"/>
    <rule ref="rulesets/cleancode.xml/ElseExpression"/>
    <rule ref="rulesets/cleancode.xml/MissingImport"/>
    <rule ref="rulesets/cleancode.xml/UndefinedVariable"/>

    <!-- Allow static calls on the OTPHP\TOTP external library facade only.
         TOTPCreatorService is the single adapter that calls TOTP::create(),
         isolating all other classes from static access. -->
    <rule ref="rulesets/cleancode.xml/StaticAccess">
        <properties>
            <property name="exceptions" value="OTPHP\TOTP"/>
        </properties>
    </rule>
</ruleset>
