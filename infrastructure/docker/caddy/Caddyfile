{
    {$CADDY_GLOBAL_OPTIONS}

    frankenphp {
        {$FRANKENPHP_CONFIG}
    }

    {$CADDY_DEBUG}
    auto_https disable_redirects
}

{$SERVER_NAME} {
    log {
        output stderr
        format json
    }
    {$CADDY_EXTRA_CONFIG}

    # AC: NFR-39 - limit request body size to prevent memory exhaustion
    request_body {
        max_size 64KB
    }

    root * /srv/app/public
    encode zstd gzip
    header -Server

    vulcain

    php_server
    file_server
}

:8081 {
    log {
        output stderr
        format json
    }

    root * /srv/app/public
    header -Server

    vulcain
    php_server {
        env APP_ENV {$CADDY_PHP_APP_ENV:test}
        env APP_DEBUG {$CADDY_PHP_APP_DEBUG:0}
    }
    encode zstd gzip
    file_server
}
