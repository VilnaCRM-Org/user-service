<doctrine-mongo-mapping
  xmlns="http://doctrine-project.org/schemas/odm/doctrine-mongo-mapping"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://doctrine-project.org/schemas/odm/doctrine-mongo-mapping
                                            http://doctrine-project.org/schemas/odm/doctrine-mongo-mapping.xsd"
>

    <document name="App\User\Domain\Entity\PasskeyCredential" db="user_service" collection="passkey_credentials">
        <id field-name="id" type="string" strategy="NONE" />

        <field field-name="userId" name="user_id" type="string" />
        <field field-name="credentialId" name="credential_id" type="string" />
        <field field-name="credentialRecord" name="credential_record" type="string" />
        <field field-name="label" type="string" />
        <field field-name="createdAt" name="created_at" type="date_immutable" />
        <field field-name="lastUsedAt" name="last_used_at" type="date_immutable" nullable="true" />

        <indexes>
            <index unique="true">
                <key name="credential_id" />
            </index>
            <index>
                <key name="user_id" order="asc" />
            </index>
        </indexes>
    </document>
</doctrine-mongo-mapping>
