SIGNIN_LOCKOUT_MAX_ATTEMPTS=20
SIGNIN_LOCKOUT_SECONDS=900
SIGNIN_LOCKOUT_ATTEMPT_WINDOW_SECONDS=3600
# Insecure key for test environment only
TWO_FACTOR_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

