# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

###> doctrine/mongodb-odm-bundle ###
MONGODB_USER=root
MONGODB_PASSWORD=secret
MONGODB_PORT=27017
MONGODB_VERSION=8.0
MONGODB_URL=mongodb://root:secret@database:27017
###< doctrine/mongodb-odm-bundle ###

REDIS_URL=redis://redis:6379/1

MESSENGER_RETRY_DELAY_MS=60000

PASSWORD_RESET_TOKEN_LENGTH=32
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1
PASSWORD_RESET_RATE_LIMIT_MAX_REQUESTS=1000
PASSWORD_RESET_RATE_LIMIT_INTERVAL="1 hour"

LOAD_TEST_CONFIG=tests/Load/config.json.dist
AWS_EMF_NAMESPACE=UserService/BusinessMetrics
DOMAIN_EVENTS_QUEUE_NAME=domain-events
FAILED_DOMAIN_EVENTS_QUEUE_NAME=failed-domain-events
DOMAIN_EVENTS_TRANSPORT_DSN=sqs://localstack:${LOCALSTACK_PORT:-4566}/000000000000/${DOMAIN_EVENTS_QUEUE_NAME}?sslmode=disable&region=us-east-1
FAILED_DOMAIN_EVENTS_TRANSPORT_DSN=sqs://localstack:${LOCALSTACK_PORT:-4566}/000000000000/${FAILED_DOMAIN_EVENTS_QUEUE_NAME}?sslmode=disable&region=us-east-1
OAUTH_PERSIST_ACCESS_TOKEN=1
OAUTH_ENABLE_IMPLICIT_GRANT=1

###> oauth-social-signin ###
# Test environment: HTTP is acceptable for callback URIs
OAUTH_GITHUB_CLIENT_ID=test_github_client_id
OAUTH_GITHUB_CLIENT_SECRET=test_github_client_secret
OAUTH_GITHUB_REDIRECT_URI=http://localhost/api/auth/social/github/callback

OAUTH_GOOGLE_CLIENT_ID=test_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=test_google_client_secret
OAUTH_GOOGLE_REDIRECT_URI=http://localhost/api/auth/social/google/callback

OAUTH_FACEBOOK_CLIENT_ID=test_facebook_client_id
OAUTH_FACEBOOK_CLIENT_SECRET=test_facebook_client_secret
OAUTH_FACEBOOK_REDIRECT_URI=http://localhost/api/auth/social/facebook/callback

OAUTH_TWITTER_CLIENT_ID=test_twitter_client_id
OAUTH_TWITTER_CLIENT_SECRET=test_twitter_client_secret
OAUTH_TWITTER_REDIRECT_URI=http://localhost/api/auth/social/twitter/callback

OAUTH_STATE_TTL_SECONDS=600
OAUTH_PROVIDER_HTTP_CONNECT_TIMEOUT_MS=1500
OAUTH_PROVIDER_HTTP_TIMEOUT_MS=5000
OAUTH_PROVIDER_HTTP_MAX_RETRIES=1
###< oauth-social-signin ###
